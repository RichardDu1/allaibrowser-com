---
import BaseLayout from '../../layouts/BaseLayout.astro';

const pageTitle = 'All AI Browser | Terminal Benchmarks';
const pageDescription = 'Hardcore benchmarks and tests for AI browsers, headless agents, and Web UI automation frameworks.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://allaibrowser.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <!-- Cyberpunk Terminal Hero -->
  <header class="scanline min-h-[70vh] flex flex-col justify-center border-b border-[#27272a] relative overflow-hidden">
    <!-- Grid Background -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(39,39,42,0.3)_1px,transparent_1px),linear-gradient(90deg,rgba(39,39,42,0.3)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_10%,transparent_100%)] pointer-events-none -z-10"></div>
    
    <div class="container max-w-5xl mx-auto px-6 z-10">
      <div class="mb-4 text-primary text-sm font-bold animate-pulse">
        > system initialization sequence complete...
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 uppercase tracking-tighter">
        Benchmarking<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">The Autonomous Web</span>
      </h1>
      <p class="text-lg md:text-xl text-muted max-w-2xl mb-10 leading-relaxed border-l-2 border-accent pl-4">
        We execute automated tests against Browser Use, Stagehand, and proprietary AI browsers. We measure DOM traversal speed, visual CAPTCHA solve rates, and deterministic reliability.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 font-bold text-sm">
        <a href="#benchmarks" class="px-6 py-3 bg-primary text-black hover:bg-white transition-colors border border-primary text-center uppercase tracking-widest shadow-[0_0_15px_rgba(34,197,94,0.4)]">
          > execute_tests()
        </a>
        <a href="/en/docs/" class="px-6 py-3 bg-transparent text-white border border-[#27272a] hover:border-accent hover:text-accent transition-colors text-center uppercase tracking-widest">
          > read_docs()
        </a>
      </div>
    </div>
  </header>

  <!-- Live Terminal Output Mock -->
  <section id="benchmarks" class="container max-w-5xl mx-auto px-6 py-20">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl text-white font-bold uppercase tracking-widest border-b border-[#27272a] pb-2 inline-block">
        Latest Benchmark Runs
      </h2>
      <div class="text-accent text-xs animate-pulse">[LIVE: RUNNING]</div>
    </div>

    <!-- Terminal Window -->
    <div class="bg-[#09090b] border border-[#27272a] rounded shadow-2xl overflow-hidden font-mono text-sm">
      <div class="bg-[#18181b] px-4 py-2 border-b border-[#27272a] flex items-center gap-2">
        <div class="w-3 h-3 bg-[#52525b] rounded-full"></div>
        <div class="w-3 h-3 bg-[#52525b] rounded-full"></div>
        <div class="w-3 h-3 bg-[#52525b] rounded-full"></div>
        <div class="ml-4 text-xs text-[#52525b]">root@allaibrowser:~# htop</div>
      </div>
      
      <div class="p-6 space-y-6">
        <!-- Test 1 -->
        <div>
          <div class="flex justify-between text-white mb-2">
            <span>[TASK_01] Browser Use: Expedia Flight Booking</span>
            <span class="text-primary">PASS (89%)</span>
          </div>
          <div class="w-full bg-[#18181b] h-2 rounded overflow-hidden">
            <div class="bg-primary h-full w-[89%] shadow-[0_0_10px_rgba(34,197,94,0.8)]"></div>
          </div>
          <div class="text-[#52525b] text-xs mt-2">> DOM nodes parsed: 14,203 | Time: 14.2s | Tokens: 42k</div>
        </div>

        <!-- Test 2 -->
        <div>
          <div class="flex justify-between text-white mb-2">
            <span>[TASK_02] Stagehand: React SPA Data Extraction</span>
            <span class="text-accent">PASS (96%)</span>
          </div>
          <div class="w-full bg-[#18181b] h-2 rounded overflow-hidden">
            <div class="bg-accent h-full w-[96%] shadow-[0_0_10px_rgba(168,85,247,0.8)]"></div>
          </div>
          <div class="text-[#52525b] text-xs mt-2">> Playwright hooks injected | Time: 4.1s | Tokens: 12k</div>
        </div>

        <!-- Test 3 -->
        <div>
          <div class="flex justify-between text-white mb-2">
            <span>[TASK_03] AutoGPT: Cloudflare Turnstile Bypass</span>
            <span class="text-red-500">FAIL (12%)</span>
          </div>
          <div class="w-full bg-[#18181b] h-2 rounded overflow-hidden">
            <div class="bg-red-500 h-full w-[12%] shadow-[0_0_10px_rgba(239,68,68,0.8)]"></div>
          </div>
          <div class="text-[#52525b] text-xs mt-2">> ERROR: Timeout waiting for selector | Element obscured</div>
        </div>
      </div>
    </div>
  </section>

</BaseLayout>
