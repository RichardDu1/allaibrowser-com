---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

const allReviews = await getCollection('reviews');
const sortedReviews = allReviews.sort((a, b) => {
  const parseSuccess = (y) => parseFloat(y.replace(/[^0-9.]/g, '')) || 0;
  return parseSuccess(b.data.successRate) - parseSuccess(a.data.successRate);
});
const topAgents = sortedReviews.slice(0, 3);

const pageTitle = 'All AI Browser | Terminal Benchmarks';
const pageDescription = 'Hardcore benchmarks and tests for AI browsers, headless agents, and Web UI automation frameworks.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://allaibrowser.com/en/"
  schema={{ type: 'WebSite', data: { description: pageDescription } }}
>
  <!-- Cyberpunk Terminal Hero -->
  <header class="scanline min-h-[70vh] flex flex-col justify-center border-b border-[#27272a] relative overflow-hidden">
    <!-- Grid Background -->
    <div class="absolute inset-0 bg-[linear-gradient(rgba(39,39,42,0.3)_1px,transparent_1px),linear-gradient(90deg,rgba(39,39,42,0.3)_1px,transparent_1px)] bg-[size:40px_40px] [mask-image:radial-gradient(ellipse_60%_60%_at_50%_50%,#000_10%,transparent_100%)] pointer-events-none -z-10"></div>
    
    <div class="container max-w-5xl mx-auto px-6 z-10">
      <div class="mb-4 text-primary text-sm font-bold animate-pulse">
        > system initialization sequence complete...
      </div>
      <h1 class="text-5xl md:text-7xl font-bold text-white mb-6 uppercase tracking-tighter">
        Benchmarking<br/>
        <span class="text-transparent bg-clip-text bg-gradient-to-r from-primary to-accent">The Autonomous Web</span>
      </h1>
      <p class="text-lg md:text-xl text-muted max-w-2xl mb-10 leading-relaxed border-l-2 border-accent pl-4">
        We execute automated tests against Browser Use, Stagehand, and proprietary AI browsers. We measure DOM traversal speed, visual CAPTCHA solve rates, and deterministic reliability.
      </p>

      <div class="flex flex-col sm:flex-row gap-4 font-bold text-sm">
        <a href="/en/reviews/" class="px-6 py-3 bg-primary text-black hover:bg-white transition-colors border border-primary text-center uppercase tracking-widest shadow-[0_0_15px_rgba(34,197,94,0.4)]">
          > execute_tests()
        </a>
        <a href="https://github.com/allaibrowser" target="_blank" class="px-6 py-3 bg-transparent text-white border border-[#27272a] hover:border-accent hover:text-accent transition-colors text-center uppercase tracking-widest">
          > read_docs()
        </a>
      </div>
    </div>
  </header>

  <!-- Live Terminal Output Mock -->
  <section id="benchmarks" class="container max-w-5xl mx-auto px-6 py-20">
    <div class="flex items-center justify-between mb-8">
      <h2 class="text-2xl text-white font-bold uppercase tracking-widest border-b border-[#27272a] pb-2 inline-block">
        Latest Benchmark Runs
      </h2>
      <div class="text-accent text-xs animate-pulse">[LIVE: RUNNING]</div>
    </div>

    <!-- Terminal Window -->
    <div class="bg-[#09090b] border border-[#27272a] rounded shadow-2xl overflow-hidden font-mono text-sm">
      <div class="bg-[#18181b] px-4 py-2 border-b border-[#27272a] flex items-center gap-2">
        <div class="w-3 h-3 bg-[#52525b] rounded-full"></div>
        <div class="w-3 h-3 bg-[#52525b] rounded-full"></div>
        <div class="w-3 h-3 bg-[#52525b] rounded-full"></div>
        <div class="ml-4 text-xs text-[#52525b]">root@allaibrowser:~# htop --sort success_rate</div>
      </div>
      
      <div class="p-6 space-y-6">
        {topAgents.length > 0 ? topAgents.map((agent, index) => {
          const rawRate = parseFloat(agent.data.successRate.replace(/[^0-9.]/g, '')) || 0;
          let statusColor = "text-primary";
          let barColor = "bg-primary shadow-[0_0_10px_rgba(34,197,94,0.8)]";
          let statusText = `PASS (${agent.data.successRate})`;
          
          if (rawRate < 50) {
            statusColor = "text-red-500";
            barColor = "bg-red-500 shadow-[0_0_10px_rgba(239,68,68,0.8)]";
            statusText = `FAIL (${agent.data.successRate})`;
          } else if (rawRate < 90) {
            statusColor = "text-yellow-500";
            barColor = "bg-yellow-500 shadow-[0_0_10px_rgba(234,179,8,0.8)]";
            statusText = `WARN (${agent.data.successRate})`;
          }
          
          const taskId = String(index + 1).padStart(2, '0');
          
          return (
            <a href={`/en/reviews/${agent.id.split('/').pop()}`} class="block group">
              <div class="flex justify-between text-white mb-2">
                <span class="group-hover:text-accent transition-colors">[TASK_${taskId}] {agent.data.title}</span>
                <span class={statusColor}>{statusText}</span>
              </div>
              <div class="w-full bg-[#18181b] h-2 rounded overflow-hidden">
                <div class={`${barColor} h-full w-[${rawRate}%]`}></div>
              </div>
              <div class="text-[#52525b] text-xs mt-2 group-hover:text-white transition-colors">
                > DOM Parsing: {agent.data.domParsingSpeed} | Tokens: {agent.data.tokenCostPerTask} | CAPTCHA: {agent.data.captchaBypassRate}
              </div>
            </a>
          );
        }) : (
           <div class="text-[#52525b] text-xs">> WAITING FOR STDOUT... (Run generation script)</div>
        )}
      </div>
    </div>
    
    <div class="mt-8 text-center">
      <a href="/en/reviews/" class="text-accent hover:text-white text-sm uppercase tracking-widest font-bold underline decoration-accent/50 underline-offset-4 transition-colors">
        [ View Full Registry ]
      </a>
    </div>
  </section>

</BaseLayout>
