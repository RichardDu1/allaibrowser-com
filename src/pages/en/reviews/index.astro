---
import { getCollection } from 'astro:content';
import BaseLayout from '../../../layouts/BaseLayout.astro';

const allReviews = await getCollection('reviews');
const sortedReviews = allReviews.sort((a, b) => {
  const parseSuccess = (y) => parseFloat(y.replace(/[^0-9.]/g, '')) || 0;
  return parseSuccess(b.data.successRate) - parseSuccess(a.data.successRate);
});

const pageTitle = 'Agent Benchmarks Leaderboard | All AI Browser';
const pageDescription = 'Browse our live leaderboard of AI web agents, headless browsers, and automation frameworks.';
---

<BaseLayout
  title={pageTitle}
  description={pageDescription}
  canonical="https://allaibrowser.com/en/reviews/"
>
  <main class="max-w-5xl mx-auto px-6 pt-32 pb-24 font-mono">
    <header class="mb-16 border-b border-[#27272a] pb-8">
      <div class="text-primary text-sm font-bold mb-2">> cat /var/log/benchmarks.txt</div>
      <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 uppercase tracking-tighter">Agent Leaderboard</h1>
      <p class="text-lg text-muted">Deterministic tests across Playwright, Puppeteer, and native implementations.</p>
    </header>

    <div class="space-y-8">
      {sortedReviews.length > 0 ? sortedReviews.map((agent, idx) => {
        const rawRate = parseFloat(agent.data.successRate.replace(/[^0-9.]/g, '')) || 0;
        let barColor = "bg-primary";
        if (rawRate < 50) barColor = "bg-red-500";
        else if (rawRate < 90) barColor = "bg-yellow-500";
        
        return (
        <a href={`/en/reviews/${agent.id.split('/').pop()}`} class="block glass-card bg-[#09090b] border border-[#27272a] hover:border-accent p-6 rounded transition-colors group relative">
          {idx === 0 && <div class="absolute top-0 right-0 bg-primary text-black text-xs font-bold px-2 py-1 rounded-bl">RANK_01</div>}
          
          <div class="flex flex-col md:flex-row justify-between md:items-center gap-4 mb-4">
            <div>
              <span class="text-xs text-accent uppercase tracking-widest border border-accent/30 bg-accent/10 px-2 py-1 rounded mb-2 inline-block">
                {agent.data.agentType}
              </span>
              <h3 class="text-2xl font-bold text-white group-hover:text-primary transition-colors">{agent.data.title}</h3>
            </div>
            <div class="text-right">
              <div class="text-3xl font-bold text-white">{agent.data.successRate}</div>
              <div class="text-[10px] text-muted uppercase tracking-widest">Success Rate</div>
            </div>
          </div>
          
          <div class="w-full bg-[#18181b] h-1 rounded overflow-hidden mb-6">
            <div class={`${barColor} h-full w-[${rawRate}%]`}></div>
          </div>
          
          <div class="grid grid-cols-3 gap-4 text-xs">
            <div class="border-l border-[#27272a] pl-3">
              <div class="text-muted mb-1">DOM Parse</div>
              <div class="text-white">{agent.data.domParsingSpeed}</div>
            </div>
            <div class="border-l border-[#27272a] pl-3">
              <div class="text-muted mb-1">Cost/Task</div>
              <div class="text-white">{agent.data.tokenCostPerTask}</div>
            </div>
            <div class="border-l border-[#27272a] pl-3">
              <div class="text-muted mb-1">CAPTCHA</div>
              <div class="text-white">{agent.data.captchaBypassRate}</div>
            </div>
          </div>
        </a>
      )}) : (
        <div class="text-center text-muted py-12 border border-dashed border-[#27272a]">
          > NO DATA FOUND. RUNNING TESTS...
        </div>
      )}
    </div>
  </main>
</BaseLayout>
